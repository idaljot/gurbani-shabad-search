---
import TablaPlayer from '../components/TablaPlayer.astro';
const { title = 'Gurbani Shabad Search' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.jsdelivr.net/npm/tone@14.8.49/build/Tone.js"></script>
    <style>
      :root {
        --bg: #fbf7f0;
        --panel: #ffffff;
        --ink: #2a2320;
        --muted: #7a7068;
        --accent: #b5651d;
        --accent-soft: #f0e0cc;
        --border: #e5dccb;
        font-family: 'Segoe UI', system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }
      h1 {
        font-size: 1.9rem;
        margin-bottom: 0.25rem;
      }
      p.subtitle {
        color: var(--muted);
        margin-top: 0;
      }
    </style>
  </head>
  <body>
    <TablaPlayer id="global-tabla" variant="bar" />
    <main>
      <slot />
    </main>
  </body>
</html>
