---
import { RESOURCE_PLAYLISTS } from '../data/raags.js';
const {
  title = 'Gurbani Kirtan Swar Notation',
  description = 'Search Gurbani shabads by typing the first letters of each word, browse by raag or writer, and view sur/taal notation for kirtan.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- One combined request (matches how these were originally loaded) with
         display=optional for all three families. Gurmukhi glyphs in
         particular have very different vertical/horizontal metrics than
         their Latin fallback, so swapping the font in after layout
         (display=swap) reflows every shabad line on shabad detail pages —
         confirmed as the CLS Lighthouse flagged there. An earlier attempt
         split Gurmukhi into its own request with display=optional and left
         swap on the other two; that made detail-page CLS worse (two
         separately-timed font loads instead of one), so this uses one
         request and applies `optional` uniformly instead. `optional` uses
         the fallback for the whole render if the font isn't ready almost
         immediately, avoiding a later reflow entirely. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=DM+Sans:wght@400;500;600&family=Noto+Sans+Gurmukhi:wght@400;500;600&display=optional"
      rel="stylesheet"
    />
    <!-- Self-hosted (Tone.js 14.8.49; was loaded from a CDN) — see
         public/vendor/tone.js.LICENSE.txt for the MIT license header that
         ships alongside it. defer: this is a 349KB synchronous script
         that was blocking HTML parsing (and first paint) on every page,
         even though the tabla player it powers isn't needed until the user
         interacts with it. `defer` lets it download in parallel without
         blocking rendering, while still guaranteeing it runs (in document
         order, before TablaPlayer's own module script further down the
         page) before the page is considered "loaded" — so window.Tone is
         available by the time TablaPlayer's init code runs, same as before. -->
    <script src="/vendor/tone.js" defer></script>
    <style>
      :root {
        --bg: #fbf7f0;
        --panel: #ffffff;
        --ink: #2a2320;
        --muted: #7a7068;
        --accent: #b5651d;
        --accent-soft: #f0e0cc;
        --border: #e5dccb;
        --font-body: 'DM Sans', system-ui, sans-serif;
        --font-heading: 'Fraunces', Georgia, serif;
        --font-gurmukhi: 'Noto Sans Gurmukhi', sans-serif;
        font-family: var(--font-body);
      }
      :global(*) { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4.5rem;
      }
      :global(h1) {
        font-family: var(--font-heading);
        font-size: 2.3rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
      }
      :global(h2) {
        font-family: var(--font-heading);
        font-weight: 600;
      }
      p.subtitle {
        color: var(--muted);
        margin-top: 0;
      }
      .site-footer {
        max-width: 900px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 2.5rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.85rem;
      }
      .footer-playlists {
        margin: 0;
      }
      .footer-playlists a {
        color: var(--accent);
      }
      .footer-copyright {
        margin: 0.6rem 0 0;
      }
      .footer-copyright a {
        color: var(--accent);
      }
      .footer-copyright .cc-badge {
        height: 16px;
        width: auto;
        aspect-ratio: 88 / 31;
        vertical-align: middle;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p class="footer-playlists">
        More class resources:
        {Object.entries(RESOURCE_PLAYLISTS).map(([name, url], i) => (
          <>
            {i > 0 && ' · '}
            <a href={url} target="_blank" rel="noopener">{name}</a>
          </>
        ))}
      </p>
      <p class="footer-copyright">
        Created and maintained by <a href="https://daljotsingh.com" target="_blank" rel="noopener">Daljot Singh</a>
        &middot; Sur/taal notation and compilation licensed under
        <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>
        <img class="cc-badge" src="https://licensebuttons.net/l/by-nc/4.0/88x31.png" alt="CC BY-NC 4.0 license badge" width="88" height="31" />
        &mdash; free for non-commercial use with attribution. Gurbani text is in the public domain.
      </p>
    </footer>
  </body>
</html>
