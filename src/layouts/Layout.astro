---
import { RESOURCE_PLAYLISTS } from '../data/raags.js';
const { title = 'Gurbani Kirtan Swar Notation' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.jsdelivr.net/npm/tone@14.8.49/build/Tone.js"></script>
    <style>
      :root {
        --bg: #fbf7f0;
        --panel: #ffffff;
        --ink: #2a2320;
        --muted: #7a7068;
        --accent: #b5651d;
        --accent-soft: #f0e0cc;
        --border: #e5dccb;
        font-family: 'Segoe UI', system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }
      h1 {
        font-size: 1.9rem;
        margin-bottom: 0.25rem;
      }
      p.subtitle {
        color: var(--muted);
        margin-top: 0;
      }
      .site-footer {
        max-width: 900px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 2.5rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.85rem;
      }
      .footer-playlists {
        margin: 0;
      }
      .footer-playlists a {
        color: var(--accent);
      }
      .footer-copyright {
        margin: 0.6rem 0 0;
      }
      .footer-copyright a {
        color: var(--accent);
      }
      .footer-copyright .cc-badge {
        height: 16px;
        width: auto;
        vertical-align: middle;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p class="footer-playlists">
        More class resources:
        {Object.entries(RESOURCE_PLAYLISTS).map(([name, url], i) => (
          <>
            {i > 0 && ' · '}
            <a href={url} target="_blank" rel="noopener">{name}</a>
          </>
        ))}
      </p>
      <p class="footer-copyright">
        Created and maintained by <a href="https://daljotsingh.com" target="_blank" rel="noopener">Daljot Singh</a>
        &middot; Sur/taal notation and compilation licensed under
        <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>
        <img class="cc-badge" src="https://licensebuttons.net/l/by-nc/4.0/88x31.png" alt="CC BY-NC 4.0 license badge" width="88" height="31" />
        &mdash; free for non-commercial use with attribution. Gurbani text is in the public domain.
      </p>
    </footer>
  </body>
</html>
