---
import Layout from '../layouts/Layout.astro';
import TablaPlayer from '../components/TablaPlayer.astro';
import records from '../data/search-index.json';
import { RAAGS } from '../data/raags.js';
import { bySourceOrder } from '../data/sources.js';

const sources = [...new Set(records.map((s) => s.source))].sort(bySourceOrder);
const raags = [...new Set(records.map((s) => s.raag))].sort();
const writers = [...new Set(records.map((s) => s.writer))].sort();
const taals = [...new Set(records.map((s) => s.taal).filter(Boolean))].sort();
const notatedCount = records.filter((s) => s.hasNotation).length;

const recentlyNotated = records
  .filter((s) => s.hasNotation && s.notatedAt)
  .sort((a, b) => new Date(b.notatedAt || 0) - new Date(a.notatedAt || 0))
  .slice(0, 3);

// Only real raags (RAAGS keys, curated to exclude structural labels like
// Vaar/Salok/Svaiyay) that actually have at least one shabad in the data.
const raagCounts = new Map();
for (const s of records) {
  raagCounts.set(s.raag, (raagCounts.get(s.raag) || 0) + 1);
}
const browsableRaags = Object.keys(RAAGS)
  .filter((name) => raagCounts.has(name))
  .map((name) => ({ name, count: raagCounts.get(name) }))
  .sort((a, b) => a.name.localeCompare(b.name));
---
<Layout title="Gurbani Kirtan Swar Notation">
  <h1>Gurbani Kirtan Swar Notation</h1>
  <p class="site-credit">
    Curated by <a href="https://www.youtube.com/@GurmatSangeetTutorials/playlists" target="_blank" rel="noopener">Bhai Jaspal Singh Ji</a>
  </p>
  <p class="subtitle">
    {records.length} shabads &middot; {notatedCount} with sur &amp; taal &middot; type the
    first letter of each word (like SikhiToTheMax)
  </p>

  <div id="controls">
    <div id="search-wrap">
      <input
        id="search-box"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="Loading search index…"
        disabled
      />
      <p id="gurmukhi-preview" aria-live="polite">Loading search index…</p>
      <div id="results-panel" class="results-panel" hidden>
        <p id="result-count"></p>
        <ul id="results"></ul>
      </div>
    </div>
    <div id="filters">
      <select id="filter-source" aria-label="Filter by source" disabled>
        <option value="">All Sources</option>
        {sources.map((s) => <option value={s}>{s}</option>)}
      </select>
      <select id="filter-raag" aria-label="Filter by raag" disabled>
        <option value="">All Raags</option>
        {raags.map((r) => <option value={r}>{r}</option>)}
      </select>
      <select id="filter-writer" aria-label="Filter by writer" disabled>
        <option value="">All Writers</option>
        {writers.map((w) => <option value={w}>{w}</option>)}
      </select>
      <select id="filter-taal" aria-label="Filter by taal" disabled>
        <option value="">All Taals</option>
        {taals.map((t) => <option value={t}>{t}</option>)}
      </select>
      <label id="notated-toggle">
        <input type="checkbox" id="filter-notated" disabled /> Only with sur/taal
      </label>
      <button id="clear-filters" type="button">Clear</button>
    </div>
  </div>

  <div id="homepage-sections">
    <section id="recent-notated">
      <h2>Recently Notated</h2>
      {recentlyNotated.length > 0 ? (
        <ul class="recent-list">
          {recentlyNotated.map((s) => (
            <li>
              <a class="result-card" href={`/shabad/${s.id}/`}>
                <div class="gurmukhi">{s.preview}</div>
                <div class="meta">
                  <span>Ang {s.ang}</span>
                  <span>{s.source}</span>
                  <span>{s.raag}</span>
                  <span>{s.writer}</span>
                  {s.taal && <span class="taal">{s.taal}</span>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="recent-empty">
          No shabads have notation yet — once sur/taal is submitted through the
          notation form, the newest additions will appear here first.
        </p>
      )}
      {notatedCount > 0 && (
        <a class="view-all-link" href="/notated/">View all notated shabads &rarr;</a>
      )}
    </section>

    <section id="browse-raag">
      <h2>Browse by Raag</h2>
      <div class="raag-chips">
        {browsableRaags.map((r) => (
          <a class="raag-chip" href={`/raag/${encodeURIComponent(r.name)}/`}>
            {r.name} <span class="raag-chip-count">{r.count}</span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <TablaPlayer id="floating-tabla" variant="floating" />

  <script>
    const KEYMAP = {
      a: '\u0a73', A: '\u0a05', e: '\u0a72', E: '\u0a13', s: '\u0a38', S: '\u0a36\u0a3c', h: '\u0a39',
      k: '\u0a15', K: '\u0a16', g: '\u0a17', G: '\u0a18',
      c: '\u0a1a', C: '\u0a1b', j: '\u0a1c', J: '\u0a1d', z: '\u0a1c\u0a3c',
      t: '\u0a1f', T: '\u0a20', f: '\u0a21', F: '\u0a22', x: '\u0a23',
      q: '\u0a24', Q: '\u0a25', d: '\u0a26', D: '\u0a27', n: '\u0a28',
      p: '\u0a2a', P: '\u0a2b', b: '\u0a2c', B: '\u0a2d', m: '\u0a2e',
      X: '\u0a2f', r: '\u0a30', l: '\u0a32', L: '\u0a32\u0a3c', v: '\u0a35', V: '\u0a5c',
      Z: '\u0a17\u0a3c', '0': '\u0a66', '1': '\u0a67', '2': '\u0a68', '3': '\u0a69', '4': '\u0a6a',
      '5': '\u0a6b', '6': '\u0a6c', '7': '\u0a6d', '8': '\u0a6e', '9': '\u0a6f',
    };

    function romanToGurmukhi(input) {
      let out = '';
      for (const ch of input) {
        if (ch === ' ') { out += ' '; continue; }
        if (KEYMAP[ch]) out += KEYMAP[ch];
      }
      return out;
    }

    // Loaded via fetch() instead of an inlined <script type="application/json">
    // blob — the previous approach embedded ~19MB directly in the HTML
    // document, which meant the browser couldn't paint anything (the search
    // box, filters, Recently Notated, ...) until that whole document had
    // arrived. Fetching it separately lets the page shell render immediately;
    // the search box stays disabled with a loading placeholder until this
    // resolves, so there's never a window where typing silently does nothing.
    let shabads = null;

    const searchBox = document.getElementById('search-box');
    const preview = document.getElementById('gurmukhi-preview');
    const filterSource = document.getElementById('filter-source');
    const filterRaag = document.getElementById('filter-raag');
    const filterWriter = document.getElementById('filter-writer');
    const filterTaal = document.getElementById('filter-taal');
    const filterNotated = document.getElementById('filter-notated');
    const clearBtn = document.getElementById('clear-filters');
    const resultsEl = document.getElementById('results');
    const countEl = document.getElementById('result-count');
    const resultsPanel = document.getElementById('results-panel');
    const homepageSections = document.getElementById('homepage-sections');

    const loadingInputs = [searchBox, filterSource, filterRaag, filterWriter, filterTaal, filterNotated];

    fetch('/search-index.json')
      .then((res) => {
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then((data) => {
        shabads = data;
        loadingInputs.forEach((el) => { el.disabled = false; });
        searchBox.placeholder = 'Type first letters, e.g. gmsshn';
        preview.textContent = '';
      })
      .catch(() => {
        searchBox.placeholder = 'Search unavailable — please reload';
        preview.textContent = 'Search index failed to load — please reload the page.';
      });

    // The dropdown activates on either typed text or any filter \u2014 a raag/taal
    // filter chosen with an empty search box should still browse shabads via
    // the dropdown, not sit inert until the user also types something.
    function hasActiveQuery() {
      return Boolean(searchBox.value.trim()) || Boolean(filterSource.value) ||
        Boolean(filterRaag.value) || Boolean(filterWriter.value) ||
        Boolean(filterTaal.value) || filterNotated.checked;
    }

    function render() {
      if (!shabads) return;
      const raw = searchBox.value.trim();
      const query = romanToGurmukhi(raw).replace(/\s+/g, '');
      preview.textContent = raw ? 'Searching: ' + romanToGurmukhi(raw) : '';

      const active = hasActiveQuery();
      resultsPanel.hidden = !active;
      homepageSections.hidden = active;
      if (!active) return;

      const source = filterSource.value;
      const raag = filterRaag.value;
      const writer = filterWriter.value;
      const taal = filterTaal.value;
      const notatedOnly = filterNotated.checked;

      function findMatchedLine(s) {
        if (!s.lines) return null;
        return s.lines.find((l) => (l.fl || '').replace(/\s+/g, '').startsWith(query));
      }

      const matches = [];
      for (const s of shabads) {
        if (source && s.source !== source) continue;
        if (raag && s.raag !== raag) continue;
        if (writer && s.writer !== writer) continue;
        if (taal && s.taal !== taal) continue;
        if (notatedOnly && !s.hasNotation) continue;
        let preview = s.preview;
        if (query) {
          const matchedLine = findMatchedLine(s);
          if (!matchedLine) continue;
          preview = matchedLine.t;
        }
        matches.push({ s, preview });
      }

      countEl.textContent = matches.length + ' result' + (matches.length === 1 ? '' : 's');

      resultsEl.innerHTML = matches
        .slice(0, 200)
        .map(({ s, preview }) => '<li><a class="dropdown-item" href="/shabad/' + s.id + '/">' +
          '<div class="dropdown-line">' + (preview || '') + '</div>' +
          '<div class="dropdown-tags">' +
          '<span>' + s.raag + '</span>' +
          '<span>' + s.writer + '</span>' +
          (s.taal ? '<span class="taal">' + s.taal + '</span>' : '') +
          (s.hasNotation ? '<span class="has-sur">sur \u2713</span>' : '') +
          '</div></a></li>')
        .join('');
    }

    [searchBox, filterSource, filterRaag, filterWriter, filterTaal].forEach((el) =>
      el.addEventListener('input', render)
    );
    filterNotated.addEventListener('change', render);
    clearBtn.addEventListener('click', () => {
      searchBox.value = '';
      filterSource.value = '';
      filterRaag.value = '';
      filterWriter.value = '';
      filterTaal.value = '';
      filterNotated.checked = false;
      render();
    });

    render();
  </script>

  <style>
    #controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
    #search-wrap { position: relative; }
    #search-box {
      width: 100%; padding: 0.8rem 1rem; font-size: 1.05rem; border: 1px solid var(--border);
      border-radius: 8px; background: var(--panel);
    }
    #search-box:disabled, #filters select:disabled { opacity: 0.6; cursor: wait; }
    #gurmukhi-preview { margin: 0; min-height: 1.2em; font-size: 1rem; color: var(--accent); font-family: var(--font-gurmukhi); }
    #filters { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
    #filters select, #filters button {
      padding: 0.5rem 0.75rem; border: 1px solid var(--border);
      border-radius: 8px; background: var(--panel); font-size: 0.95rem;
    }
    #filters button { cursor: pointer; color: var(--accent); font-weight: 600; }
    #notated-toggle { font-size: 0.9rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; }

    .results-panel {
      margin-top: 0.35rem;
      background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
      box-shadow: 0 8px 24px rgba(42, 35, 32, 0.15);
      max-height: 440px; overflow-y: auto; padding: 0.75rem 0.9rem;
    }
    #result-count { color: var(--muted); font-size: 0.85rem; margin: 0 0 0.6rem; }
    #results { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
    /* Rows below are injected via innerHTML at runtime (see render() in the
       script), so they never receive Astro's scoping attribute — these
       selectors must be :global() or they silently never match. */
    :global(.dropdown-item) {
      display: block; background: var(--bg); border: 1px solid transparent;
      border-radius: 8px; padding: 0.6rem 0.75rem; text-decoration: none; color: inherit;
      transition: background 0.1s, border-color 0.1s;
    }
    :global(.dropdown-item:hover) { background: var(--accent-soft); border-color: var(--border); }
    :global(.dropdown-line) {
      font-family: var(--font-gurmukhi); font-size: 1.05rem; margin-bottom: 0.3rem;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    :global(.dropdown-tags) { display: flex; gap: 0.35rem; flex-wrap: wrap; font-size: 0.68rem; }
    :global(.dropdown-tags span) { background: var(--accent-soft); color: var(--accent); padding: 0.1rem 0.5rem; border-radius: 999px; font-weight: 500; }
    :global(.dropdown-tags span.has-sur) { background: #d8ecd8; color: #2e6b2e; }

    .result-card {
      display: block; background: var(--panel); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.05rem 1.2rem; text-decoration: none; color: inherit;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    .result-card:hover { border-color: var(--border); box-shadow: 0 4px 16px rgba(42, 35, 32, 0.1); }
    .gurmukhi { font-family: var(--font-gurmukhi); font-size: 1.25rem; margin-bottom: 0.55rem; line-height: 1.5; }
    .meta { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.72rem; }
    .meta span { background: var(--accent-soft); color: var(--accent); padding: 0.15rem 0.55rem; border-radius: 999px; font-weight: 500; }
    .meta span.has-sur { background: #d8ecd8; color: #2e6b2e; }
    .meta span.shabad-id { background: transparent; border: 1px solid var(--border); color: var(--muted); }

    .site-credit { color: var(--muted); margin: 0 0 0.5rem; font-size: 0.9rem; }
    .site-credit a { color: var(--accent); }

    #recent-notated { margin-bottom: 2.25rem; }
    #recent-notated h2 {
      font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--muted); font-weight: 600; margin: 0 0 0.75rem;
      font-family: var(--font-body);
    }
    .recent-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; }
    .recent-empty {
      color: var(--muted); font-size: 0.9rem; margin: 0;
      background: var(--panel); border: 1px dashed var(--border);
      border-radius: 8px; padding: 0.8rem 1rem;
    }
    .view-all-link {
      display: inline-block; margin-top: 0.9rem; color: var(--accent);
      font-size: 0.9rem; font-weight: 600; text-decoration: none;
    }
    .view-all-link:hover { text-decoration: underline; }

    #browse-raag h2 {
      font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--muted); font-weight: 600; margin: 0 0 0.75rem;
      font-family: var(--font-body);
    }
    .raag-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .raag-chip {
      display: inline-flex; align-items: center; gap: 0.35rem;
      background: var(--panel); border: 1px solid var(--border);
      border-radius: 999px; padding: 0.4rem 0.85rem; font-size: 0.85rem;
      color: var(--ink); text-decoration: none;
      transition: border-color 0.1s, box-shadow 0.1s;
    }
    .raag-chip:hover { border-color: var(--accent); box-shadow: 0 2px 8px rgba(42, 35, 32, 0.08); }
    .raag-chip-count {
      background: var(--accent-soft); color: var(--accent); font-weight: 600;
      font-size: 0.72rem; padding: 0.05rem 0.4rem; border-radius: 999px;
    }
  </style>
</Layout>
