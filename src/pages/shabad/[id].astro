---
import Layout from '../../layouts/Layout.astro';
import TablaPlayer from '../../components/TablaPlayer.astro';
import shabads from '../../data/shabads.json';
import { RAAGS } from '../../data/raags.js';
import { bySourceOrder } from '../../data/sources.js';

export function getStaticPaths() {
  // shabads.json's own array order is sorted by ang ALONE across every
  // source combined (see fetch-base.mjs) — Dasam Granth ang 1 and Vaaran
  // Bhai Gurdas ang 1 land right next to Guru Granth Sahib Ji's ang 1, even
  // though they're unrelated angs in different books. Re-sort by source
  // (canonical order, same as the Source filter elsewhere), then ang, then
  // original array index as a tiebreaker — that index reflects the crawl's
  // own reading-order for shabads sharing an ang, since fetch-base.mjs's
  // final sort is stable and fetch-notation.mjs's merge preserves order.
  const ordered = shabads
    .map((s, i) => ({ s, i }))
    .sort((a, b) => bySourceOrder(a.s.source, b.s.source) || (a.s.ang - b.s.ang) || (a.i - b.i))
    .map((x) => x.s);

  return ordered.map((s, idx) => {
    const prev = ordered[idx - 1];
    const next = ordered[idx + 1];
    return {
      params: { id: s.shabadId },
      props: {
        shabad: s,
        // Stay within the same source rather than crossing e.g. from the
        // last Guru Granth Sahib Ji shabad into the first Dasam Granth one.
        prevId: prev && prev.source === s.source ? prev.shabadId : null,
        nextId: next && next.source === s.source ? next.shabadId : null,
      },
    };
  });
}

const { shabad, prevId, nextId } = Astro.props;
const hasNotation = Boolean(shabad.sthayi || shabad.antara || shabad.taal || shabad.key || shabad.alaap);

const raagInfo = RAAGS[shabad.raag];
const hasMusicalInfo = Boolean(
  raagInfo && (
    raagInfo.thaat || raagInfo.arohi || raagInfo.avrohi || raagInfo.vadi || raagInfo.samvadi ||
    (raagInfo.komal && raagInfo.komal.length) || (raagInfo.teevra && raagInfo.teevra.length) ||
    (raagInfo.varjit && raagInfo.varjit.length) || raagInfo.time || raagInfo.mood || raagInfo.notes
  )
);
const hasPlaylist = Boolean(raagInfo && raagInfo.youtubePlaylist);
const showRaagSection = hasMusicalInfo || hasPlaylist;
---
<Layout title={`${shabad.raag} · ${shabad.writer}`}>
  <div class="top-row">
    <p class="back"><a href="/">&larr; Back to search</a></p>
    <nav class="shabad-nav compact" aria-label="Adjacent shabads">
      {prevId ? (
        <a class="nav-btn" href={`/shabad/${prevId}/`}>&larr; Previous</a>
      ) : (
        <span class="nav-btn disabled" aria-disabled="true">&larr; Previous</span>
      )}
      {nextId ? (
        <a class="nav-btn" href={`/shabad/${nextId}/`}>Next &rarr;</a>
      ) : (
        <span class="nav-btn disabled" aria-disabled="true">Next &rarr;</span>
      )}
    </nav>
  </div>

  <div class="shabad-header">
    <div class="tags">
      <span>Ang {shabad.ang}</span>
      <span>{shabad.source || 'Guru Granth Sahib Ji'}</span>
      <span>{shabad.raag}</span>
      <span>{shabad.writer}</span>
      <span class="shabad-id">ID: {shabad.shabadId}</span>
    </div>
    {hasNotation && (
      <div class="taal-bar">
        {shabad.taal && <span><strong>Taal:</strong> {shabad.taal}</span>}
        {shabad.tempo && <span><strong>Tempo:</strong> {shabad.tempo}</span>}
        {shabad.key && <span><strong>Key:</strong> {shabad.key}</span>}
      </div>
    )}
  </div>

  <TablaPlayer
    id="shabad-tabla"
    variant="embedded"
    presetTaal={shabad.taal || 'Teentaal'}
    presetTempo={shabad.tempo || 80}
  />

  <div class={hasNotation ? 'panels two' : 'panels one'}>
    <section class="text-panel">
      <h2>Shabad</h2>
      <div class="lines">
        {shabad.textLines.map((line) => <p class="line">{line}</p>)}
      </div>
    </section>

    {hasNotation && (
      <section class="notation-panel">
        <h2>Sur / Notation</h2>
        {shabad.alaap && (
          <div class="block">
            <p class="block-label">Alaap</p>
            <pre>{shabad.alaap}</pre>
          </div>
        )}
        {shabad.sthayi && (
          <div class="block">
            <p class="block-label">Sthayi</p>
            <pre>{shabad.sthayi}</pre>
          </div>
        )}
        {shabad.antara && (
          <div class="block">
            <p class="block-label">Antara</p>
            <pre>{shabad.antara}</pre>
          </div>
        )}
      </section>
    )}
  </div>

  {!hasNotation && (
    <p class="no-sur">
      No sur or taal has been added for this shabad yet.
      Contributions come in through the class form.
    </p>
  )}

  {showRaagSection && (
    <details class="raag-section">
      <summary>About this Raag &mdash; {shabad.raag}</summary>
      <div class="raag-body">
        {hasPlaylist && (
          <a class="raag-youtube" href={raagInfo.youtubePlaylist} target="_blank" rel="noopener">
            &#9654; Watch on YouTube
          </a>
        )}
        {hasMusicalInfo ? (
          <dl class="raag-facts">
            {raagInfo.thaat && <><dt>Thaat</dt><dd>{raagInfo.thaat}</dd></>}
            {raagInfo.arohi && <><dt>Arohi</dt><dd>{raagInfo.arohi}</dd></>}
            {raagInfo.avrohi && <><dt>Avrohi</dt><dd>{raagInfo.avrohi}</dd></>}
            {raagInfo.vadi && <><dt>Vadi</dt><dd>{raagInfo.vadi}</dd></>}
            {raagInfo.samvadi && <><dt>Samvadi</dt><dd>{raagInfo.samvadi}</dd></>}
            {raagInfo.komal && raagInfo.komal.length > 0 && <><dt>Komal swars</dt><dd>{raagInfo.komal.join(', ')}</dd></>}
            {raagInfo.teevra && raagInfo.teevra.length > 0 && <><dt>Teevra swars</dt><dd>{raagInfo.teevra.join(', ')}</dd></>}
            {raagInfo.varjit && raagInfo.varjit.length > 0 && <><dt>Varjit swars</dt><dd>{raagInfo.varjit.join(', ')}</dd></>}
            {raagInfo.time && <><dt>Time</dt><dd>{raagInfo.time}</dd></>}
            {raagInfo.mood && <><dt>Mood</dt><dd>{raagInfo.mood}</dd></>}
            {raagInfo.notes && <><dt>Notes</dt><dd>{raagInfo.notes}</dd></>}
          </dl>
        ) : (
          <p class="raag-coming-soon">Detailed raag information coming soon.</p>
        )}
      </div>
    </details>
  )}

  <nav class="shabad-nav bottom" aria-label="Adjacent shabads">
    {prevId ? (
      <a class="nav-btn" href={`/shabad/${prevId}/`}>&larr; Previous shabad</a>
    ) : (
      <span class="nav-btn disabled" aria-disabled="true">&larr; Previous shabad</span>
    )}
    {nextId ? (
      <a class="nav-btn" href={`/shabad/${nextId}/`}>Next shabad &rarr;</a>
    ) : (
      <span class="nav-btn disabled" aria-disabled="true">Next shabad &rarr;</span>
    )}
  </nav>

  <style>
    .top-row {
      display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
      gap: 0.75rem; margin: 0 0 1.25rem;
    }
    .back { margin: 0; }
    .back a { color: var(--accent); text-decoration: none; font-size: 0.9rem; }

    .shabad-nav { display: flex; gap: 0.5rem; }
    .nav-btn {
      display: inline-block; text-decoration: none;
      color: var(--accent); background: var(--accent-soft); border: 1px solid transparent;
      border-radius: 999px; transition: border-color 0.15s;
    }
    .nav-btn:hover { border-color: var(--accent); }
    .nav-btn.disabled {
      color: var(--muted); background: transparent; border-color: var(--border);
      opacity: 0.6; cursor: not-allowed;
    }
    .shabad-nav.compact .nav-btn { font-size: 0.85rem; font-weight: 500; padding: 0.35rem 0.85rem; }

    /* The end-of-page nav: most people arrive here for the tabla player or
       notation, not just to read the text, so "done with this page" can
       happen at any point below — this sits after everything (raag info
       included) as the natural "what's next" moment, rather than being
       glued to the bottom of the shabad-text card specifically (which,
       side-by-side with a taller notation panel, wouldn't even reliably
       land at the visual end of the page). */
    .shabad-nav.bottom {
      justify-content: space-between; margin-top: 2rem; padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }
    .shabad-nav.bottom .nav-btn { font-size: 0.95rem; font-weight: 600; padding: 0.65rem 1.3rem; }

    .shabad-header { margin-bottom: 1.5rem; }
    .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; font-size: 0.78rem; margin-bottom: 0.75rem; }
    .tags span { background: var(--accent-soft); color: var(--accent); padding: 0.15rem 0.6rem; border-radius: 999px; font-weight: 500; }
    .tags span.shabad-id { background: transparent; border: 1px solid var(--border); color: var(--muted); }
    .taal-bar {
      display: flex; gap: 1.25rem; flex-wrap: wrap; background: #fbf0dd;
      border: 1px solid #e8d4ad; border-radius: 8px; padding: 0.55rem 0.9rem; font-size: 0.95rem;
    }
    .taal-bar strong { font-weight: 600; }

    .panels { display: grid; gap: 1.5rem; margin-top: 1.5rem; }
    .panels.two { grid-template-columns: 1fr 1fr; }
    .panels.one { grid-template-columns: 1fr; }
    @media (max-width: 700px) {
      .panels.two { grid-template-columns: 1fr; }
    }

    section h2 {
      font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--muted); font-weight: 600; margin: 0 0 0.75rem;
      font-family: var(--font-body);
    }
    .text-panel, .notation-panel {
      background: var(--panel); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.25rem 1.4rem;
    }
    .notation-panel {
      background: #fdf6ee;
      border-color: #ecdcc4;
    }
    .lines { display: flex; flex-direction: column; gap: 0.45rem; }
    .line { margin: 0; font-size: 1.15rem; line-height: 1.7; font-family: var(--font-gurmukhi); }

    .block { margin-bottom: 1.25rem; }
    .block:last-child { margin-bottom: 0; }
    .block-label { margin: 0 0 0.4rem; font-size: 0.9rem; font-weight: 600; color: var(--accent); font-family: var(--font-body); }
    pre {
      margin: 0; font-family: var(--font-gurmukhi), ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      font-size: 1.05rem; line-height: 1.9; white-space: pre; overflow-x: auto;
      background: #fffdf9; padding: 0.85rem 1rem; border-radius: 4px;
      border-left: 3px solid var(--accent);
    }
    .no-sur {
      margin-top: 1.5rem; color: var(--muted); font-size: 0.9rem;
      background: var(--panel); border: 1px dashed var(--border);
      border-radius: 8px; padding: 0.8rem 1rem;
    }

    .raag-section {
      margin-top: 1.5rem; background: #f4f1ea; border: 1px solid var(--border);
      border-radius: 10px; padding: 1rem 1.25rem;
    }
    .raag-section summary {
      cursor: pointer; font-weight: 600; font-size: 0.95rem; color: var(--accent);
      font-family: var(--font-body);
    }
    .raag-body { margin-top: 1rem; }
    .raag-youtube {
      display: inline-block; background: var(--accent); color: #fff; text-decoration: none;
      font-size: 0.9rem; font-weight: 600; padding: 0.5rem 0.9rem; border-radius: 999px;
      margin-bottom: 0.8rem;
    }
    .raag-facts { display: grid; grid-template-columns: auto 1fr; gap: 0.4rem 1rem; margin: 0; font-size: 0.9rem; }
    .raag-facts dt { color: var(--muted); font-weight: 600; }
    .raag-facts dd { margin: 0; }
    .raag-coming-soon { margin: 0; color: var(--muted); font-size: 0.9rem; }
  </style>
</Layout>
