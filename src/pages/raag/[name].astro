---
import Layout from '../../layouts/Layout.astro';
import shabads from '../../data/shabads.json';
import { RAAGS } from '../../data/raags.js';

export function getStaticPaths() {
  return Object.keys(RAAGS).map((name) => ({
    params: { name },
  }));
}

const { name } = Astro.params;
const raagInfo = RAAGS[name];

const raagShabads = shabads
  .filter((s) => s.raag === name)
  .map((s) => ({
    id: s.shabadId,
    ang: s.ang,
    source: s.source || 'Guru Granth Sahib Ji',
    writer: s.writer,
    preview: s.previewLine || s.firstLine || '',
    taal: s.taal || null,
    hasNotation: Boolean(s.sthayi || s.antara || s.taal),
  }));

// Surface notated shabads first (max 3) since they're the ones a class can
// actually sing along with sur; the general list below is trimmed too so a
// large raag (hundreds of shabads) doesn't dump an unusable wall of cards.
const notatedInRaag = raagShabads.filter((s) => s.hasNotation).slice(0, 3);
const notatedIds = new Set(notatedInRaag.map((s) => s.id));
const generalList = raagShabads.filter((s) => !notatedIds.has(s.id)).slice(0, 5);

const hasMusicalInfo = Boolean(
  raagInfo && (
    raagInfo.thaat || raagInfo.jati || raagInfo.aroh || raagInfo.avroh || raagInfo.vadi || raagInfo.samvadi ||
    (raagInfo.komal && raagInfo.komal.length) || (raagInfo.teevra && raagInfo.teevra.length) ||
    (raagInfo.varjit && raagInfo.varjit.length) || raagInfo.tukda ||
    raagInfo.time || raagInfo.mood || raagInfo.notes
  )
);
const hasSwarDetails = Boolean(
  raagInfo && (
    raagInfo.thaat || raagInfo.jati || raagInfo.aroh || raagInfo.avroh || raagInfo.vadi || raagInfo.samvadi ||
    (raagInfo.komal && raagInfo.komal.length) || (raagInfo.teevra && raagInfo.teevra.length) ||
    (raagInfo.varjit && raagInfo.varjit.length) || raagInfo.tukda
  )
);
const hasPlaylist = Boolean(raagInfo && raagInfo.youtubePlaylist);

// Review-status badge: only meaningful when there's actual info to review in
// the first place — a raag with no data at all gets neither badge, same
// "nothing to show" treatment as the coming-soon message below.
const status = (raagInfo && raagInfo.status) || 'draft';
const isApproved = status === 'approved';
---
<Layout title={`${name} · Gurbani Kirtan Swar Notation`}>
  <p class="back"><a href="/">&larr; Back to search</a></p>
  <h1>{name}</h1>
  <p class="subtitle">{raagShabads.length} shabad{raagShabads.length === 1 ? '' : 's'}</p>

  {hasPlaylist && (
    <a class="raag-youtube" href={raagInfo.youtubePlaylist} target="_blank" rel="noopener">
      &#9654; Watch on YouTube
    </a>
  )}

  {hasMusicalInfo ? (
    <section class="raag-info">
      <div class="raag-info-header">
        <h2>About this Raag</h2>
        {isApproved ? (
          <span class="status-badge status-approved">&#10003; Reviewed by Bhai Jaspal Singh Ji</span>
        ) : (
          <span class="status-badge status-draft">
            {raagInfo.sourceNote || 'Compiled from public sources'} &mdash; pending review by Bhai Jaspal Singh Ji
          </span>
        )}
      </div>

      {(raagInfo.mood || raagInfo.time) && (
        <div class="raag-highlights">
          {raagInfo.mood && <p class="raag-mood">{raagInfo.mood}</p>}
          {raagInfo.time && (
            <p class="raag-time">
              <strong>Traditional time:</strong> {raagInfo.time}
              <span class="raag-time-caveat">
                In Gurmat Sangeet, raags express mood rather than being restricted to a
                specific clock time (unlike Hindustani classical) &mdash; this is a
                traditional association, not a rule.
              </span>
            </p>
          )}
        </div>
      )}

      {hasSwarDetails && (
        <dl class="raag-facts">
          {raagInfo.thaat && <><dt>Thaat</dt><dd>{raagInfo.thaat}</dd></>}
          {raagInfo.jati && <><dt>Jati</dt><dd>{raagInfo.jati}</dd></>}
          {raagInfo.aroh && <><dt>Aroh</dt><dd>{raagInfo.aroh}</dd></>}
          {raagInfo.avroh && <><dt>Avroh</dt><dd>{raagInfo.avroh}</dd></>}
          {raagInfo.vadi && <><dt>Vadi</dt><dd>{raagInfo.vadi}</dd></>}
          {raagInfo.samvadi && <><dt>Samvadi</dt><dd>{raagInfo.samvadi}</dd></>}
          {raagInfo.komal && raagInfo.komal.length > 0 && <><dt>Komal swars</dt><dd>{raagInfo.komal.join(', ')}</dd></>}
          {raagInfo.teevra && raagInfo.teevra.length > 0 && <><dt>Teevra swars</dt><dd>{raagInfo.teevra.join(', ')}</dd></>}
          {raagInfo.varjit && raagInfo.varjit.length > 0 && <><dt>Varjit swars</dt><dd>{raagInfo.varjit.join(', ')}</dd></>}
          {raagInfo.tukda && <><dt>Tukda</dt><dd>{raagInfo.tukda}</dd></>}
        </dl>
      )}

      {raagInfo.notes && <p class="raag-notes">{raagInfo.notes}</p>}
    </section>
  ) : (
    <p class="raag-coming-soon">Detailed raag information coming soon.</p>
  )}

  {notatedInRaag.length > 0 && (
    <section class="notated-section">
      <h2>Notated in this Raag</h2>
      <ul class="recent-list">
        {notatedInRaag.map((s) => (
          <li>
            <a class="result-card" href={`/shabad/${s.id}/`}>
              <div class="gurmukhi">{s.preview}</div>
              <div class="meta">
                <span>Ang {s.ang}</span>
                <span>{s.source}</span>
                <span>{s.writer}</span>
                {s.taal && <span class="taal">{s.taal}</span>}
                <span class="has-sur">sur &#10003;</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
      <a class="view-all-link" href={`/notated/?raag=${encodeURIComponent(name)}`}>View all notated in this raag &rarr;</a>
    </section>
  )}

  <h2>Shabads in {name}</h2>
  <p class="showing-count">
    Showing {generalList.length} of {raagShabads.length}
    {raagShabads.length > generalList.length && (
      <> &mdash; <a class="view-all-link inline" href={`/browse/?raag=${encodeURIComponent(name)}`}>view all in this raag &rarr;</a></>
    )}
  </p>
  <ul class="recent-list">
    {generalList.map((s) => (
      <li>
        <a class="result-card" href={`/shabad/${s.id}/`}>
          <div class="gurmukhi">{s.preview}</div>
          <div class="meta">
            <span>Ang {s.ang}</span>
            <span>{s.source}</span>
            <span>{s.writer}</span>
            {s.taal && <span class="taal">{s.taal}</span>}
            {s.hasNotation && <span class="has-sur">sur &#10003;</span>}
          </div>
        </a>
      </li>
    ))}
  </ul>

  <style>
    .back { margin: 0 0 1rem; }
    .back a { color: var(--accent); text-decoration: none; font-size: 0.9rem; }
    .raag-youtube {
      display: inline-block; background: var(--accent); color: #fff; text-decoration: none;
      font-size: 0.9rem; font-weight: 600; padding: 0.5rem 0.9rem; border-radius: 999px;
      margin: 0.75rem 0 1.25rem;
    }
    .raag-info { margin: 0.75rem 0 1.5rem; }
    .raag-info-header {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem;
      margin-bottom: 0.75rem;
    }
    .raag-info-header h2 { margin: 0; }
    .status-badge {
      display: inline-block; padding: 0.2rem 0.65rem; border-radius: 999px;
      font-size: 0.72rem; font-weight: 500; font-family: var(--font-body);
      text-transform: none; letter-spacing: normal;
    }
    .status-draft { background: var(--accent-soft); color: var(--accent); }
    .status-approved { background: #d8ecd8; color: #2e6b2e; }
    .raag-highlights {
      background: #fbf0dd; border: 1px solid #e8d4ad; border-radius: 8px;
      padding: 0.7rem 0.9rem; margin-bottom: 0.9rem;
    }
    .raag-mood { margin: 0; font-size: 0.98rem; }
    .raag-time { margin: 0.5rem 0 0; font-size: 0.9rem; }
    .raag-time:first-child { margin-top: 0; }
    .raag-time strong { font-weight: 600; }
    .raag-time-caveat {
      display: block; margin-top: 0.25rem; color: var(--muted);
      font-size: 0.78rem; font-style: italic;
    }
    .raag-facts { display: grid; grid-template-columns: auto 1fr; gap: 0.4rem 1rem; margin: 0; font-size: 0.9rem; }
    .raag-facts dt { color: var(--muted); font-weight: 600; }
    .raag-facts dd { margin: 0; }
    .raag-notes { margin: 0.9rem 0 0; color: var(--muted); font-size: 0.85rem; }
    .raag-coming-soon { margin: 0.75rem 0 1.5rem; color: var(--muted); font-size: 0.9rem; }

    h2 {
      font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--muted); font-weight: 600; margin: 0 0 0.75rem;
      font-family: var(--font-body);
    }
    .notated-section { margin-bottom: 2rem; }
    .view-all-link {
      display: inline-block; margin-top: 0.9rem; color: var(--accent);
      font-size: 0.9rem; font-weight: 600; text-decoration: none;
    }
    .view-all-link:hover { text-decoration: underline; }
    .view-all-link.inline { display: inline; margin-top: 0; font-weight: 500; }
    .showing-count { color: var(--muted); font-size: 0.85rem; margin: 0 0 0.85rem; }
    .recent-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; }
    .result-card {
      display: block; background: var(--panel); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.05rem 1.2rem; text-decoration: none; color: inherit;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    .result-card:hover { border-color: var(--border); box-shadow: 0 4px 16px rgba(42, 35, 32, 0.1); }
    .gurmukhi { font-family: var(--font-gurmukhi); font-size: 1.25rem; margin-bottom: 0.55rem; line-height: 1.5; }
    .meta { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.72rem; }
    .meta span { background: var(--accent-soft); color: var(--accent); padding: 0.15rem 0.55rem; border-radius: 999px; font-weight: 500; }
    .meta span.has-sur { background: #d8ecd8; color: #2e6b2e; }
  </style>
</Layout>
