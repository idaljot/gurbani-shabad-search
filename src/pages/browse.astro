---
import Layout from '../layouts/Layout.astro';
import searchIndex from '../data/search-index.json';
import { bySourceOrder } from '../data/sources.js';

const sources = [...new Set(searchIndex.map((s) => s.source))].sort(bySourceOrder);
const raags = [...new Set(searchIndex.map((s) => s.raag))].sort();
const writers = [...new Set(searchIndex.map((s) => s.writer))].sort();
const taals = [...new Set(searchIndex.map((s) => s.taal).filter(Boolean))].sort();
---
<Layout title="Browse All Shabads · Gurbani Kirtan Swar Notation">
  <p class="back"><a href="/">&larr; Back to search</a></p>
  <h1>Browse All Shabads</h1>
  <p class="subtitle">{searchIndex.length} shabads total &mdash; filter to narrow the list</p>

  <div id="filters">
    <select id="filter-source" aria-label="Filter by source" disabled>
      <option value="">All Sources</option>
      {sources.map((s) => <option value={s}>{s}</option>)}
    </select>
    <select id="filter-raag" aria-label="Filter by raag" disabled>
      <option value="">All Raags</option>
      {raags.map((r) => <option value={r}>{r}</option>)}
    </select>
    <select id="filter-writer" aria-label="Filter by writer" disabled>
      <option value="">All Writers</option>
      {writers.map((w) => <option value={w}>{w}</option>)}
    </select>
    <select id="filter-taal" aria-label="Filter by taal" disabled>
      <option value="">All Taals</option>
      {taals.map((t) => <option value={t}>{t}</option>)}
    </select>
    <button id="clear-filters" type="button">Clear</button>
  </div>

  <p id="result-count">Loading shabad list…</p>
  <ul id="results" class="recent-list"></ul>

  <script>
    const UNFILTERED_CAP = 200;

    // Loaded via fetch() instead of an inlined <script type="application/json">
    // blob — see index.astro for the full rationale. Filters stay disabled
    // (see the `disabled` attributes above) and #result-count shows a loading
    // message until this resolves, so there's never a window where changing
    // a filter silently does nothing.
    let records = null;

    const filterSource = document.getElementById('filter-source');
    const filterRaag = document.getElementById('filter-raag');
    const filterWriter = document.getElementById('filter-writer');
    const filterTaal = document.getElementById('filter-taal');
    const clearBtn = document.getElementById('clear-filters');
    const resultsEl = document.getElementById('results');
    const countEl = document.getElementById('result-count');

    function render() {
      if (!records) return;
      const source = filterSource.value;
      const raag = filterRaag.value;
      const writer = filterWriter.value;
      const taal = filterTaal.value;
      const anyFilterActive = Boolean(source || raag || writer || taal);

      const matches = records.filter((s) => {
        if (source && s.source !== source) return false;
        if (raag && s.raag !== raag) return false;
        if (writer && s.writer !== writer) return false;
        if (taal && s.taal !== taal) return false;
        return true;
      });

      // Once a filter narrows the set, show every match (a raag can have
      // hundreds of shabads and this page is specifically the "see
      // everything" destination). With no filter at all, cap the render so
      // we're not building 11,000+ DOM nodes for a view nobody scrolls that far.
      const shown = anyFilterActive ? matches : matches.slice(0, UNFILTERED_CAP);

      countEl.textContent = anyFilterActive || matches.length <= UNFILTERED_CAP
        ? matches.length + ' result' + (matches.length === 1 ? '' : 's')
        : `Showing first ${UNFILTERED_CAP} of ${matches.length} — use a filter to narrow results`;

      resultsEl.innerHTML = shown
        .map((s) => '<li><a class="result-card" href="/shabad/' + s.id + '/">' +
          '<div class="gurmukhi">' + (s.preview || '') + '</div>' +
          '<div class="meta">' +
          '<span>Ang ' + s.ang + '</span>' +
          '<span>' + s.source + '</span>' +
          '<span>' + s.raag + '</span>' +
          '<span>' + s.writer + '</span>' +
          (s.taal ? '<span class="taal">' + s.taal + '</span>' : '') +
          (s.hasNotation ? '<span class="has-sur">sur ✓</span>' : '') +
          '</div></a></li>')
        .join('');
    }

    // Pre-apply filters from the URL, e.g. /browse/?raag=Raag%20Bilaaval —
    // URLSearchParams already URL-decodes the values for us.
    function applyFiltersFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const map = { source: filterSource, raag: filterRaag, writer: filterWriter, taal: filterTaal };
      for (const [key, select] of Object.entries(map)) {
        const value = params.get(key);
        if (value && [...select.options].some((o) => o.value === value)) {
          select.value = value;
        }
      }
    }

    [filterSource, filterRaag, filterWriter, filterTaal].forEach((el) =>
      el.addEventListener('change', render)
    );
    clearBtn.addEventListener('click', () => {
      filterSource.value = '';
      filterRaag.value = '';
      filterWriter.value = '';
      filterTaal.value = '';
      render();
    });

    // Pre-select filters from the URL immediately — this doesn't need the
    // fetched data, just the (already server-rendered) option lists — so
    // the dropdowns reflect the URL right away even while still disabled.
    applyFiltersFromUrl();

    fetch('/browse-index.json')
      .then((res) => {
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then((data) => {
        records = data;
        [filterSource, filterRaag, filterWriter, filterTaal].forEach((el) => { el.disabled = false; });
        render();
      })
      .catch(() => {
        countEl.textContent = 'Shabad list failed to load — please reload the page.';
      });
  </script>

  <style>
    .back { margin: 0 0 1rem; }
    .back a { color: var(--accent); text-decoration: none; font-size: 0.9rem; }
    #filters { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin: 1.25rem 0; }
    #filters select, #filters button {
      padding: 0.5rem 0.75rem; border: 1px solid var(--border);
      border-radius: 8px; background: var(--panel); font-size: 0.95rem;
    }
    #filters button { cursor: pointer; color: var(--accent); font-weight: 600; }
    #filters select:disabled { opacity: 0.6; cursor: wait; }
    #result-count { color: var(--muted); font-size: 0.9rem; margin: 0.25rem 0 1.25rem; min-height: 1.2em; }
    #results { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; }

    /* Rows are injected via innerHTML at runtime, so these must be :global()
       or Astro's scoping attribute never matches them — see the equivalent
       note in index.astro / notated.astro. */
    :global(.result-card) {
      display: block; background: var(--panel); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.05rem 1.2rem; text-decoration: none; color: inherit;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    :global(.result-card:hover) { border-color: var(--border); box-shadow: 0 4px 16px rgba(42, 35, 32, 0.1); }
    :global(.gurmukhi) { font-family: var(--font-gurmukhi); font-size: 1.25rem; margin-bottom: 0.55rem; line-height: 1.5; }
    :global(.meta) { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.72rem; }
    :global(.meta span) { background: var(--accent-soft); color: var(--accent); padding: 0.15rem 0.55rem; border-radius: 999px; font-weight: 500; }
    :global(.meta span.has-sur) { background: #d8ecd8; color: #2e6b2e; }
  </style>
</Layout>
